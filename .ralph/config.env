RALPH_KIT_HOME="/Users/victortran/Coding/Resources/ralph-kit"

# Optional. Set only if auto-discovery does not find your shared kit.
# RALPH_KIT_HOME="/Users/victortran/Coding/Resources/ralph-kit"

RALPH_ISSUE_SEARCH="label:AFK -label:HITL"
RALPH_ISSUE_LIMIT=20
RALPH_PROMPT_FILE=".ralph/prompt.md"
RALPH_CLAUDE_ALLOWED_TOOLS="Edit,Write,Bash,Read,Glob,Grep"

# Codex runtime:
# - full: no sandbox/approvals (default)
# - sandbox: workspace-write with no approval prompts
RALPH_CODEX_MODE="full"

RALPH_COMPLETE_MARKER="<promise>COMPLETE</promise>"
